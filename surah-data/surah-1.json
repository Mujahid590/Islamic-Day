    "ayahs": [
        {
            "number": 1,
            "arabic": "اَلۡحَمۡدُ لِلّٰهِ رَبِّ الۡعٰلَمِيۡنَ",
            "translation": ""
        },
        {
            "number": 2,
            "arabic":   "الرَّحۡمٰنِ الرَّحِيۡمِ‏",
            "translation": ""
        },
        {
            "number": 3,
            "arabic":  "مٰلِكِ يَوۡمِ الدِّيۡنِ‏",
            "translation": ""
        },
        {
            "number": 4,
            "arabic": "اِيَّاكَ نَعۡبُدُ وَاِيَّاكَ نَسۡتَعِيۡنُ",
            "translation": ""
        },
        {
            "number": 5,
            "arabic": "ۙ‏اِهۡدِنَا الصِّرَاطَ الۡمُسۡتَقِيۡمَ",
            "translation": ""
        },
        {
            "number": 6,
            "arabic": "صِرَاطَ الَّذِيۡنَ اَنۡعَمۡتَ عَلَيۡهِمۡ",
            "translation": ""
        },
        {
            "number": 7,
            "arabic": "غَيۡرِ الۡمَغۡضُوۡبِ عَلَيۡهِمۡ وَلَا الضَّآلِّيۡنَ",
            "translation": ""
        }
    ]
