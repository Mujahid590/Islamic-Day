            "number": 1,
            "arabic": "بِسۡمِ للّٰهِ الرَّحۡمٰنِ الرَّحِيۡمِ",
            "translation": "(আরম্ভ করছি) পরম করুণাময় অসীম দয়াময় আল্লাহর নামে।"
        },
        {
            "number": 2,
            "arabic":   "اَلۡحَمۡدُ لِلّٰهِ رَبِّ الۡعٰلَمِيۡنَ",
            "translation": ""
        },
        {
            "number": 3,
            "arabic":  "الرَّحۡمٰنِ الرَّحِيۡمِۙ",
            "translation": ""
        },
        {
            "number": 4,
            "arabic": "مٰلِكِ يَوۡمِ الدِّيۡنِ",
            "translation": ""
        },
        {
            "number": 5,
            "arabic": "ۙاِيَّاكَ نَعۡبُدُ وَاِيَّاكَ نَسۡتَعِيۡنُ",
            "translation": ""
        },
        {
            "number": 6,
            "arabic": "اِهۡدِنَا الصِّرَاطَ الۡمُسۡتَقِيۡمَ",
