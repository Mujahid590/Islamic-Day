{
    "id": 1,
    "name_ar": "الفاتحة",
    "name_bn": "আল-ফাতিহা",
    "name_en": "Al-Fatihah",
    "ayat_count": 7,
    "place": "মক্কী", 
    "ayahs": [
        {
            "number": 1,
            "arabic":  "اَلْحَمْدُ لِلّٰهِ رَبِّ الْعٰلَمِيْنَ",
            "translation": "শুরু করছি আল্লাহর নামে যিনি পরম করুণাময় ও অতি দয়ালু।"
        },
        {
            "number": 2,
            "arabic": "الرَّحْمٰنِ الرَّحِیْمِ",
            "translation": "সমস্ত প্রশংসা আল্লাহর জন্য, যিনি সমস্ত জগতের পালনকর্তা।"
        },
        {
            "number": 3,
            "arabic": "مٰلِكِ یَوْمِ الدِّیْنِ",
            "translation": "যিনি পরম করুণাময় ও অতি দয়ালু।"
        },
        {
            "number": 4,
            "arabic": "اِیَّاكَ نَعْبُدُ وَ اِیَّاكَ نَسْتَعِیْنُ",
            "translation": "যিনি বিচার দিনের মালিক।"
        },
        {
            "number": 5,
            "arabic": "اِهْدِنَا الصِّرَاطَ الْمُسْتَقِیْمَ",
            "translation": "আমরা শুধুমাত্র তোমারই ইবাদত করি এবং শুধুমাত্র তোমারই সাহায্য প্রার্থনা করি।"
        },
        {
            "number": 6,
            "arabic": "اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ",
            "translation": "আমাদেরকে সরল পথ দেখাও।"
        },
        {
            "number": 7,
            "arabic": "صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ",
            "translation": "তাদের পথ, যাদেরকে তুমি নেয়ামত দান করেছ, তাদের পথ, যাদের প্রতি তোমার গজব নাযিল হয়নি এবং যারা পথভ্রষ্ট হয়নি।"
        }
    ]
}
